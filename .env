# Dota 2 Analytics Pipeline Configuration
# OpenDota API (optional - increases rate limit)
OPENDOTA_API_KEY=

# Number of public matches to fetch per batch
MATCH_BATCH_SIZE=50

# Delay between API calls (seconds) - respect rate limits
API_DELAY=1.2

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=dota2-match-logs

# Elasticsearch
ES_HOST=elasticsearch
ES_PORT=9200

# HDFS
HDFS_NAMENODE=hdfs://namenode:9000

# Spark
SPARK_MASTER=spark://spark-master:7077
